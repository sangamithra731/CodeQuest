generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  level        Int       @default(1)
  xp           Int       @default(0)
  coins        Int       @default(0)
  streak       Int       @default(0)
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  refreshTokens      RefreshToken[]
  progress           Progress[]
  badges             UserBadge[]
  certificates       Certificate[]
  placementAttempts  PlacementAttempt[]
  submissions        Submission[]
  problemCompletions ProblemCompletion[]
  savedSolutions     SavedSolution[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Language {
  id          String   @id @default(uuid())
  slug        String   @unique // "python", "javascript"
  name        String
  description String   @db.Text
  icon        String? // emoji or icon key
  difficulty  String   @default("Beginner") // Beginner | Intermediate | Advanced
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  modules      Module[]
  certificates Certificate[]

  @@map("languages")
}

model Module {
  id         String   @id @default(uuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  slug       String
  title      String
  order      Int      @default(0)

  levels Level[]

  @@unique([languageId, slug])
  @@map("modules")
}

model Level {
  id       String @id @default(uuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug     String
  title    String
  order    Int    @default(0)
  theory   String @db.Text
  examples Json // [{ code, explanation }]
  practice Json // [{ prompt, starterCode, solution }]
  xpReward Int    @default(50)

  questions Question[]
  progress  Progress[]

  @@unique([moduleId, slug])
  @@map("levels")
}

model Question {
  id           String @id @default(uuid())
  levelId      String
  level        Level  @relation(fields: [levelId], references: [id], onDelete: Cascade)
  question     String @db.Text
  options      Json // ["opt1", "opt2", "opt3", "opt4"]
  correctIndex Int
  order        Int    @default(0)

  @@map("questions")
}

model Progress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  levelId     String
  level       Level     @relation(fields: [levelId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  bestScore   Int       @default(0) // percentage, 0-100
  attempts    Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, levelId])
  @@map("progress")
}

model Badge {
  id          String @id @default(uuid())
  code        String @unique // "first_steps", "seven_day_streak"
  name        String
  description String
  icon        String @default("★")

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Certificate {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  issuedAt   DateTime @default(now())

  @@unique([userId, languageId])
  @@map("certificates")
}

model Company {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  logo        String?
  salaryRange String?
  pattern     String   @db.Text
  syllabus    Json
  available   Boolean  @default(false) // false = "coming soon"
  createdAt   DateTime @default(now())

  questions PlacementQuestion[]
  attempts  PlacementAttempt[]

  @@map("companies")
}

model PlacementQuestion {
  id           String  @id @default(uuid())
  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type         String // "aptitude" | "coding" | "technical" | "hr"
  question     String  @db.Text
  options      Json? // for MCQ aptitude questions
  correctIndex Int?
  answer       String? @db.Text // explanation for coding/technical/HR
  difficulty   String  @default("Medium")
  order        Int     @default(0)

  @@map("placement_questions")
}

model SkillTrack {
  id              String   @id @default(uuid())
  slug            String   @unique
  name            String
  summary         String   @db.Text
  skills          Json // [{ title, points: [...] }]
  certifications  Json // [string]
  companyTable    Json // [{ company, emphasis }] or [{ company, focus, problems }]
  sampleQuestions Json // [string]
  createdAt       DateTime @default(now())

  @@map("skill_tracks")
}

model PlacementAttempt {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  scorePercent   Int
  totalQuestions Int
  correctCount   Int
  attemptedAt    DateTime @default(now())

  @@map("placement_attempts")
}

model EligibilityRule {
  id                  String   @id @default(uuid())
  minCourseCompletion Int      @default(70) // percent
  minCertificates     Int      @default(1)
  minXp               Int      @default(500)
  minQuizAverage      Int      @default(60) // percent
  minStreak           Int      @default(0)
  updatedAt           DateTime @updatedAt

  @@map("eligibility_rules")
}

model Problem {
  id          String   @id @default(uuid())
  slug        String   @unique
  platform    String   @default("leetcode") // "leetcode" | "hackerrank" | "codechef" | etc.
  title       String
  difficulty  String   @default("Easy")
  topic       String
  description String   @db.Text
  constraints String?  @db.Text
  examples    Json
  starterCode Json
  videoUrl    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  testCases      TestCase[]
  submissions    Submission[]
  completions    ProblemCompletion[]
  savedSolutions SavedSolution[]

  @@map("problems")
}

model TestCase {
  id        String  @id @default(uuid())
  problemId String
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input     String  @db.Text // raw stdin the judge will feed the program
  expected  String  @db.Text // expected stdout, trimmed-compared
  isHidden  Boolean @default(false) // hidden cases run on submit but aren't shown to the student
  order     Int     @default(0)

  @@map("test_cases")
}

model Submission {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language    String // "javascript" | "python" | "java" | "cpp"
  code        String   @db.Text
  status      String // "Accepted" | "Wrong Answer" | "Runtime Error" | "Time Limit Exceeded" | "Compile Error"
  passedCount Int      @default(0)
  totalCount  Int      @default(0)
  runtimeMs   Int?
  submittedAt DateTime @default(now())

  @@map("submissions")
}

model ProblemCompletion {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, problemId])
  @@map("problem_completions")
}

model SavedSolution {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  name      String // student-given label, e.g. "Brute force attempt"
  language  String
  code      String   @db.Text
  savedAt   DateTime @default(now())

  @@map("saved_solutions")
}
